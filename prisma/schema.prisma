generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String

  services  Service[]
}

model Service {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  price       Float

  ownerId     Int
  owner        User      @relation(fields: [ownerId], references: [id])

  bookings    Booking[]
}

model Booking {
  id            Int            @id @default(autoincrement())
  customerName  String
  bookingDate   DateTime
  status        BookingStatus  @default(PENDING)

  serviceId     Int
  service       Service        @relation(fields: [serviceId], references: [id])
}